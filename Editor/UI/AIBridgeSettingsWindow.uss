/* Root Container */
.root {
    flex-grow: 1;
    background-color: rgb(56, 56, 56);
}

/* Header */
.header {
    background-color: rgb(42, 42, 42);
    padding: 15px;
    border-bottom-width: 1px;
    border-bottom-color: rgb(26, 26, 26);
}

.header-title {
    font-size: 18px;
    -unity-font-style: bold;
    color: rgb(210, 210, 210);
    margin-bottom: 5px;
}

.header-subtitle {
    font-size: 12px;
    color: rgb(150, 150, 150);
}

/* Tab Bar */
.tab-bar {
    flex-direction: row;
    background-color: rgb(48, 48, 48);
    border-bottom-width: 1px;
    border-bottom-color: rgb(26, 26, 26);
}

.tab-button {
    flex-grow: 1;
    background-color: transparent;
    border-width: 0;
    border-bottom-width: 2px;
    border-bottom-color: transparent;
    padding: 10px;
    margin: 0;
    color: rgb(180, 180, 180);
    -unity-text-align: middle-center;
}

.tab-button:hover {
    background-color: rgb(60, 60, 60);
}

.tab-active {
    border-bottom-color: rgb(58, 150, 221);
    color: rgb(210, 210, 210);
    background-color: rgb(56, 56, 56);
}

/* Content */
.content-scroll {
    flex-grow: 1;
    padding: 15px;
}

.tab-content {
    flex-grow: 1;
}

/* Sections */
.section {
    background-color: rgb(48, 48, 48);
    border-radius: 4px;
    padding: 15px;
    margin-bottom: 15px;
    border-width: 1px;
    border-color: rgb(35, 35, 35);
}

.section-title {
    font-size: 14px;
    -unity-font-style: bold;
    color: rgb(210, 210, 210);
    margin-bottom: 10px;
    padding-bottom: 5px;
    border-bottom-width: 1px;
    border-bottom-color: rgb(70, 70, 70);
}

/* Settings Items */
.setting-item {
    margin-bottom: 10px;
    margin-top: 5px;
}

.setting-item Label {
    min-width: 120px;
    color: rgb(190, 190, 190);
}

/* Info Rows */
.info-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 8px;
}

.info-label {
    min-width: 120px;
    max-width: 120px;
    color: rgb(190, 190, 190);
    flex-shrink: 0;
}

.info-value {
    flex-grow: 1;
    flex-shrink: 1;
    margin-right: 5px;
    min-width: 0;
}

.info-value > TextInput {
    background-color: rgb(42, 42, 42);
    border-color: rgb(30, 30, 30);
    overflow: hidden;
}

.info-text {
    color: rgb(180, 180, 180);
    margin-top: 5px;
    margin-bottom: 10px;
}

/* Help Text */
.help-text {
    font-size: 11px;
    color: rgb(140, 140, 140);
    margin-top: 5px;
    margin-left: 3px;
    font-style: italic;
}

/* Assembly Field */
.assembly-field {
    min-height: 60px;
}

.assembly-field > TextInput {
    min-height: 60px;
}

/* Buttons */
.small-button {
    width: 60px;
    height: 20px;
    padding: 2px;
    margin: 0;
}

.action-button {
    height: 30px;
    margin-top: 10px;
    background-color: rgb(58, 150, 221);
    border-color: rgb(48, 130, 201);
    color: white;
}

.action-button:hover {
    background-color: rgb(68, 160, 231);
}

.action-button:active {
    background-color: rgb(48, 130, 201);
}

.warning-button {
    background-color: rgb(200, 80, 80);
    border-color: rgb(180, 60, 60);
}

.warning-button:hover {
    background-color: rgb(220, 100, 100);
}

/* Footer */
.footer {
    flex-direction: row;
    justify-content: flex-end;
    padding: 10px 15px;
    background-color: rgb(48, 48, 48);
    border-top-width: 1px;
    border-top-color: rgb(26, 26, 26);
}

.primary-button {
    height: 30px;
    min-width: 100px;
    margin-left: 5px;
    background-color: rgb(58, 150, 221);
    border-color: rgb(48, 130, 201);
    color: white;
}

.primary-button:hover {
    background-color: rgb(68, 160, 231);
}

.secondary-button {
    height: 30px;
    min-width: 80px;
    margin-left: 5px;
    background-color: rgb(70, 70, 70);
    border-color: rgb(50, 50, 50);
    color: rgb(200, 200, 200);
}

.secondary-button:hover {
    background-color: rgb(80, 80, 80);
}
